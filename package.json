{
  "name": "users-research",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @users-research/web run dev",
    "dev:server": "npm --workspace @users-research/server run dev",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "dependencies": {
    "@esbuild/win32-x64": "0.27.4"
  }
}
