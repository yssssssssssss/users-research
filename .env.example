PORT=8787
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# 数据库
# 本地默认推荐 SQLite；若要切换 PostgreSQL，再改成 postgresql://...
DATABASE_URL=file:./apps/server/tmp/users-research.sqlite

# 文本模型
TEXT_MODEL_API_URL=
TEXT_MODEL_API_KEY=

# 研究调试
DISABLE_TEXT_MODELS="false"
USE_MOCK_EVIDENCE=false

# 外部搜索
TAVILY_API_KEY=
TAVILY_API_URL=
GOOGLE_PSE_API_KEY=
GOOGLE_PSE_CX=
GOOGLE_PSE_API_URL=
EXA_API_KEY=
EXA_API_URL=
SEARCH_TIMEOUT_MS=12000

# Gemini 图片模型
GEMINI_IMAGE_API_URL=
GEMINI_API_KEY=

# 即梦图片模型
JIMENG_IMAGE_API_URL=
JIMENG_API_KEY=

# JD OSS
JD_OSS_REGION=
JD_OSS_ENDPOINT=
JD_OSS_BUCKET=
JD_OSS_ACCESS_KEY_ID=
JD_OSS_SECRET_ACCESS_KEY=
JD_OSS_UPLOAD_PREFIX=

# 模型超时（毫秒）
MODEL_TEXT_TIMEOUT_MS=60000
MODEL_STREAM_TIMEOUT_MS=90000
